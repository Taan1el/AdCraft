OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Local dev without LLM keys: deterministic metrics + template issues/recs only.
MOCK_ANALYSIS=true

# Production / live demo: set MOCK_ANALYSIS=false and provide GEMINI_API_KEY and/or OPENAI_API_KEY.
# If MOCK_ANALYSIS is false and no LLM key is set, POST /analyze returns 503 with a clear error.

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002,https://taan1el.github.io
